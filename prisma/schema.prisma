generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth / OAuth ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  profile          UserProfile?
  settings         UserSettings?
  interviewSessions InterviewSession[]
  resumes          Resume[]
  voiceSessions    VoiceSession[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User profile & settings ────────────────────────────────────────────────

model UserProfile {
  userId               String   @id @map("user_id")
  experienceLevel      String   @default("intermediate") @map("experience_level")
  skills               String[] @default([])
  targetRole           String   @default("") @map("target_role")
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSettings {
  userId                String   @id @map("user_id")
  theme                 String   @default("system")
  language              String   @default("en")
  emailNotifications    Boolean  @default(true) @map("email_notifications")
  pushNotifications     Boolean  @default(false) @map("push_notifications")
  interviewReminders    Boolean  @default(true) @map("interview_reminders")
  productUpdates        Boolean  @default(false) @map("product_updates")
  browserNotifications  Boolean  @default(false) @map("browser_notifications")
  soundAlerts           Boolean  @default(true) @map("sound_alerts")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── Interview chat sessions ────────────────────────────────────────────────

model InterviewSession {
  id                  String    @id
  userId              String    @map("user_id")
  orchestrateThreadId String?   @map("orchestrate_thread_id")
  title               String    @default("New Interview")
  jobRole             String    @default("Software Engineer") @map("job_role")
  company             String?
  difficulty          String    @default("intermediate")
  type                String    @default("mixed")
  status              String    @default("active")
  durationMinutes     Int       @default(30) @map("duration_minutes")
  startedAt           DateTime  @default(now()) @map("started_at")
  endedAt             DateTime? @map("ended_at")
  shareToken          String?   @unique @map("share_token")
  sharedAt            DateTime? @map("shared_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  resumes       Resume[]
  voiceSessions VoiceSession[]
  feedback      InterviewFeedback?

  @@index([userId, updatedAt(sort: Desc)])
  @@map("interview_sessions")
}

model Message {
  id           String   @id
  sessionId    String   @map("session_id")
  role         String
  content      String   @db.Text
  questionType String?  @map("question_type")
  difficulty   String?
  tags         String[] @default([])
  feedback     String?  @db.Text
  score        Float?
  createdAt    DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Resumes ────────────────────────────────────────────────────────────────

model Resume {
  id                  String   @id
  userId              String?  @map("user_id")
  sessionId           String?  @map("session_id")
  orchestrateThreadId String?  @map("orchestrate_thread_id")
  fileName            String   @map("file_name")
  fileSize            Int      @map("file_size")
  mimeType            String   @map("mime_type")
  status              String   @default("uploaded")
  rawText             String?  @map("raw_text") @db.Text
  parsedData          Json?    @map("parsed_data")
  error               String?  @db.Text
  uploadedAt          DateTime @default(now()) @map("uploaded_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user    User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  session InterviewSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, uploadedAt(sort: Desc)])
  @@map("resumes")
}

// ─── Voice sessions ─────────────────────────────────────────────────────────

model VoiceSession {
  id                  String   @id
  userId              String?  @map("user_id")
  interviewSessionId  String?  @map("interview_session_id")
  orchestrateThreadId String?  @map("orchestrate_thread_id")
  status              String   @default("ready")
  lastTranscript      String?  @map("last_transcript") @db.Text
  language            String   @default("en")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  interviewSession InterviewSession? @relation(fields: [interviewSessionId], references: [id], onDelete: SetNull)

  @@map("voice_sessions")
}

// ─── Interview feedback ─────────────────────────────────────────────────────

model InterviewFeedback {
  id                  String   @id @default(cuid())
  sessionId           String   @unique @map("session_id")
  overallScore        Float    @map("overall_score")
  technicalScore      Float?   @map("technical_score")
  communicationScore  Float    @map("communication_score")
  problemSolvingScore Float    @map("problem_solving_score")
  strengths           String[] @default([])
  weaknesses          String[] @default([])
  recommendations     String[] @default([])
  detailedAnalysis    Json?    @map("detailed_analysis")
  createdAt           DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_feedback")
}
