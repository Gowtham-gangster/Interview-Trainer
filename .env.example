# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# IBM watsonx Orchestrate BFF (Next.js API routes at /api/*)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Use mock adapters until credentials are configured (set to false for live BFF)
# Set to true only for offline UI dev without IBM credentials
NEXT_PUBLIC_WATSONX_USE_MOCK=false

# watsonx Orchestrate service instance URL (public, no secrets)
NEXT_PUBLIC_WATSONX_SERVICE_URL=https://api.REGION.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID
NEXT_PUBLIC_WATSONX_ASSISTANT_ID=your-assistant-id

# API timeout (ms)
NEXT_PUBLIC_API_TIMEOUT_MS=30000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# IBM watsonx Configuration (server-only — never use NEXT_PUBLIC_ prefix)
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_INSTANCE_URL=https://api.REGION.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID
# Legacy alias (optional)
WATSONX_API_URL=
WATSONX_PROJECT_ID=your-project-id
# Interview_Trainer_Agent — all chat routes to this agent
WATSONX_AGENT_ID=your-interview-trainer-agent-id
# Use live for IBM Deployment Dashboard; use draft to match IBM Studio debug UI
WATSONX_AGENT_ENVIRONMENT_ID=your-environment-id
WATSONX_AGENT_ENVIRONMENT_NAME=live

# Optional: reduce response variance (0 = greedy/deterministic as possible)
WATSONX_LLM_TEMPERATURE=0
WATSONX_LLM_RANDOM_SEED=42

# IBM Watson Speech services (required for voice transcription / spoken replies)
# Use API keys from your Speech to Text and Text to Speech instances in IBM Cloud.
# If omitted, the app auto-loads service URLs from the agent voice configuration,
# but the Orchestrate API key alone may not have speech permissions.
WATSON_STT_API_KEY=your-watson-stt-api-key
WATSON_TTS_API_KEY=your-watson-tts-api-key

# Optional overrides (auto-discovered from Orchestrate voice config when omitted)
WATSON_STT_URL=https://api.REGION.speech-to-text.watson.cloud.ibm.com/instances/YOUR_INSTANCE_ID
WATSON_TTS_URL=https://api.REGION.text-to-speech.watson.cloud.ibm.com/instances/YOUR_INSTANCE_ID
WATSON_STT_MODEL=en-IN_Multimedia
WATSON_TTS_VOICE=en-US_EthanNatural

# PostgreSQL (required for auth, chat history, profiles, resumes)
# Local Docker default: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview_trainer

# Storage (if needed)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Transactional email (SMTP) — password reset, welcome, contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@mlrit.ac.in
SMTP_PASSWORD=your-app-password
SMTP_FROM=AI Interview Trainer <your-sender@mlrit.ac.in>

# Contact inbox (receives contact form submissions; defaults to SMTP_USER)
CONTACT_EMAIL=your-sender@mlrit.ac.in
# Shown on the public contact page and footer
NEXT_PUBLIC_CONTACT_EMAIL=your-sender@mlrit.ac.in
# Server-only — not exposed in page HTML (links use /linkedin redirect)
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Feature Flags (voice UI; mock mode enables voice without this)
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_VIDEO=false

# Rate limiting (required on Vercel — in-memory fallback is per-instance only)
# Create a free Redis database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Limits (production): auth 5/h, email check 30/h, reset 10/h, contact 5/h,
# chat 30/min, voice 20/min, API proxy 60/min, upload 10/h (per IP or user ID)
# Testing / staging on Vercel:
# RATE_LIMIT_RELAXED=true   — 10x higher limits (local dev is relaxed automatically)
# RATE_LIMIT_DISABLED=true  — turn off rate limits entirely (testing only; never in production)