# =============================================================================
# PRODUCTION ENVIRONMENT — copy to hosting dashboard (Vercel/Railway/etc.)
# Never commit filled values. Copy into Vercel dashboard only — not into git.
# =============================================================================

# --- Public app URLs (HTTPS required) ---
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api
NEXT_PUBLIC_WATSONX_USE_MOCK=false
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_WATSONX_SERVICE_URL=https://api.REGION.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID
NEXT_PUBLIC_API_TIMEOUT_MS=30000

# --- NextAuth (generate NEW secret — do not reuse dev secret) ---
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=GENERATE_WITH_npm_run_generate:secrets

# --- Google OAuth (add production redirect URI in Google Cloud Console) ---
# https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# --- IBM watsonx Orchestrate (ROTATE keys in IBM Cloud before go-live) ---
WATSONX_API_KEY=your-rotated-watsonx-api-key
WATSONX_INSTANCE_URL=https://api.REGION.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID
WATSONX_AGENT_ID=your-agent-id
WATSONX_AGENT_ENVIRONMENT_ID=your-environment-id
WATSONX_AGENT_ENVIRONMENT_NAME=live

# --- IBM Watson Speech (ROTATE STT/TTS keys in IBM Cloud) ---
WATSON_STT_API_KEY=your-rotated-stt-api-key
WATSON_TTS_API_KEY=your-rotated-tts-api-key

# --- PostgreSQL (managed DB with SSL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ai_interview_trainer?sslmode=require

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=AI Interview Trainer <your-sender@yourdomain.com>
CONTACT_EMAIL=your-sender@yourdomain.com
NEXT_PUBLIC_CONTACT_EMAIL=your-sender@yourdomain.com

# --- Social (server-only) ---
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-profile

# --- Rate limiting (required on Vercel — do not use RATE_LIMIT_DISABLED in production) ---
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Optional ---
NODE_ENV=production
# RATE_LIMIT_RELAXED=true
